{
  "include": ["src", "test"],
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "noImplicitOverride": true,
    "rewriteRelativeImportExtensions": true,
    "rootDir": "./",
    "types": ["node", "mocha"],
    "moduleResolution": "node",
    "baseUrl": "./",
    "paths": {
      "@": ["src/*"]
    }
  }
}
